{
  "name": "flowrad-browser-agent",
  "version": "0.1.0",
  "private": true,
  "description": "SPIKE: CDP-controlled-Chrome browser-automation sidecar for FlowRad Act mode. Driven by Stagehand v3 over the Chrome DevTools Protocol. Not yet wired into the live conductor.",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "bin": {
    "flowrad-browser-agent": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node ./dist/index.js",
    "dev": "tsx index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@browserbasehq/stagehand": "3.7.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
